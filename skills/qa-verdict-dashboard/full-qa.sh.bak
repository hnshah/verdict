#!/bin/bash
# full-qa.sh - Comprehensive Verdict Dashboard QA
# Validates data, pages, links, and content quality

set -e

REPO_ROOT="$(cd "$(dirname "$0")/../.." && pwd)"
cd "$REPO_ROOT"

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m'

ERRORS=0
WARNINGS=0

echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo "VERDICT DASHBOARD QA REPORT"
echo "Generated: $(date '+%Y-%m-%d %H:%M %Z')"
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo ""

# 1. DATA INTEGRITY
echo "${BLUE}1. DATA INTEGRITY${NC}"

if [ ! -f "dashboard-data.json" ]; then
  echo "   ${RED}❌ dashboard-data.json missing${NC}"
  ((ERRORS++))
else
  # Validate JSON
  if ! jq empty dashboard-data.json 2>/dev/null; then
    echo "   ${RED}❌ dashboard-data.json is invalid JSON${NC}"
    ((ERRORS++))
  else
    runs=$(jq '.meta.total_runs' dashboard-data.json)
    models=$(jq '.meta.total_models' dashboard-data.json)
    cases=$(jq '.meta.total_cases' dashboard-data.json)
    
    echo "   ✅ dashboard-data.json: Valid"
    echo "   - Total runs: $runs"
    echo "   - Total models: $models"
    echo "   - Total cases: $cases"
    
    # Check for duplicates
    duplicates=$(jq -r '.models | keys[]' dashboard-data.json | sort | uniq -d)
    if [ -n "$duplicates" ]; then
      echo "   ${RED}❌ Duplicate models found:${NC}"
      echo "$duplicates" | while read dup; do
        echo "      - $dup"
      done
      ((ERRORS++))
    else
      echo "   ✅ No duplicate models"
    fi
  fi
fi

echo ""

# 2. PAGE VALIDATION
echo "${BLUE}2. PAGE VALIDATION${NC}"

# Main dashboard
if [ -f "dashboard/published/index.html" ]; then
  size=$(wc -c < "dashboard/published/index.html")
  if [ $size -lt 10000 ]; then
    echo "   ${YELLOW}⚠️  Main dashboard: $size bytes (seems small)${NC}"
    ((WARNINGS++))
  else
    echo "   ✅ Main dashboard: OK ($(bc <<< "scale=1; $size / 1024") KB)"
  fi
else
  echo "   ${RED}❌ Main dashboard missing${NC}"
  ((ERRORS++))
fi

# Model pages
if [ -f "dashboard-data.json" ]; then
  expected_models=$(jq '.models | length' dashboard-data.json)
  actual_models=$(find dashboard/published/models -mindepth 1 -maxdepth 1 -type d | wc -l)
  
  if [ "$expected_models" -eq "$actual_models" ]; then
    echo "   ✅ Model pages: $actual_models/$expected_models OK"
  else
    echo "   ${RED}❌ Model pages: $actual_models/$expected_models (mismatch)${NC}"
    ((ERRORS++))
  fi
  
  # Check for empty model pages
  empty_count=0
  while IFS= read -r model_dir; do
    if [ -f "$model_dir/index.html" ]; then
      size=$(wc -c < "$model_dir/index.html")
      if [ $size -lt 1000 ]; then
        echo "   ${RED}❌ Empty model page: $(basename "$model_dir")${NC}"
        ((empty_count++))
      fi
    fi
  done < <(find dashboard/published/models -mindepth 1 -maxdepth 1 -type d)
  
  if [ $empty_count -gt 0 ]; then
    ((ERRORS+=$empty_count))
  fi
fi

# Run pages
if [ -f "dashboard-data.json" ]; then
  expected_runs=$(jq -r '[.cases[].runs[].run_id] | unique | length' dashboard-data.json)
  actual_runs=$(find dashboard/published/runs -mindepth 1 -maxdepth 1 -type d 2>/dev/null | wc -l || echo 0)
  
  if [ "$expected_runs" -eq "$actual_runs" ]; then
    echo "   ✅ Run pages: $actual_runs/$expected_runs OK"
  else
    echo "   ${YELLOW}⚠️  Run pages: $actual_runs/$expected_runs${NC}"
    ((WARNINGS++))
    
    # List missing runs
    jq -r '[.cases[].runs[].run_id] | unique | .[]' dashboard-data.json | while read run_id; do
      if [ ! -d "dashboard/published/runs/$run_id" ]; then
        echo "      Missing: $run_id"
      fi
    done
  fi
fi

echo ""

# 3. CONTENT QUALITY
echo "${BLUE}3. CONTENT QUALITY${NC}"

# Check for "Unnamed Run"
unnamed_count=$(grep -r "Unnamed Run" dashboard/published/ 2>/dev/null | wc -l || echo 0)
if [ $unnamed_count -eq 0 ]; then
  echo "   ✅ No 'Unnamed Run' entries"
else
  echo "   ${YELLOW}⚠️  Found $unnamed_count 'Unnamed Run' entries${NC}"
  ((WARNINGS++))
fi

# Check for HF links
if [ -d "dashboard/published/models" ]; then
  models_with_hf=$(grep -l "huggingface.co" dashboard/published/models/*/index.html 2>/dev/null | wc -l || echo 0)
  total_model_pages=$(find dashboard/published/models -name "index.html" 2>/dev/null | wc -l || echo 0)
  
  if [ "$models_with_hf" -eq "$total_model_pages" ]; then
    echo "   ✅ All model pages have HF links ($models_with_hf/$total_model_pages)"
  else
    echo "   ${YELLOW}⚠️  HF links: $models_with_hf/$total_model_pages${NC}"
    ((WARNINGS++))
  fi
fi

# Check for blank data fields (%)
blank_data=$(grep -r ">[%]<\|>null<\|>undefined<" dashboard/published/ 2>/dev/null | wc -l || echo 0)
if [ $blank_data -eq 0 ]; then
  echo "   ✅ No blank data fields"
else
  echo "   ${RED}❌ Found $blank_data blank data fields (%, null, undefined)${NC}"
  ((ERRORS++))
fi

echo ""

# 4. SUMMARY
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo "SUMMARY"
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"

if [ $ERRORS -eq 0 ] && [ $WARNINGS -eq 0 ]; then
  echo "${GREEN}✅ ALL CHECKS PASSED - READY TO DEPLOY${NC}"
  exit 0
elif [ $ERRORS -eq 0 ]; then
  echo "${YELLOW}⚠️  $WARNINGS warnings (review recommended)${NC}"
  echo "STATUS: OK TO DEPLOY ✅"
  exit 0
else
  echo "${RED}❌ $ERRORS errors, $WARNINGS warnings${NC}"
  echo "STATUS: DO NOT DEPLOY ❌"
  echo ""
  echo "Fix errors and re-run QA before deploying."
  exit 1
fi
