{
  "name": "verdict",
  "version": "0.2.0",
  "description": "LLM eval framework. Benchmark local and cloud models with one config file.",
  "type": "module",
  "bin": {
    "verdict": "./dist/cli/index.js"
  },
  "files": [
    "dist/",
    "eval-packs/",
    "docs/",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup",
    "prepublishOnly": "npm run build && npm run typecheck",
    "dev": "npx tsx src/cli/index.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "better-sqlite3": "^12.8.0",
    "chalk": "^5.3.0",
    "commander": "^12.0.0",
    "js-yaml": "^4.1.0",
    "openai": "^4.47.0",
    "ora": "^8.0.1",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.0.0",
    "@vitest/coverage-v8": "^4.1.1",
    "tsup": "^8.0.0",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0",
    "vitest": "^4.1.1"
  },
  "keywords": [
    "llm",
    "eval",
    "benchmark",
    "ollama",
    "mlx",
    "openai",
    "moe",
    "local-ai"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hnshah/verdict.git"
  },
  "homepage": "https://github.com/hnshah/verdict#readme",
  "bugs": {
    "url": "https://github.com/hnshah/verdict/issues"
  },
  "author": "Hiten Shah"
}
