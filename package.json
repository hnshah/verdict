{
  "name": "verdict",
  "version": "0.4.0",
  "description": "LLM eval framework. Benchmark local and cloud models with one config file.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "bin": {
    "verdict": "./dist/cli/index.js"
  },
  "files": [
    "dist/",
    "eval-packs/",
    "docs/",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup",
    "prepublishOnly": "npm run build && npm run typecheck",
    "dev": "npx tsx src/cli/index.ts",
    "benchmark": "npx tsx scripts/benchmark.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@ink-tools/ink-mouse": "^2.1.0",
    "@inkjs/ui": "^2.0.0",
    "asciichart": "^1.5.25",
    "better-sqlite3": "^12.8.0",
    "chalk": "^5.3.0",
    "commander": "^12.0.0",
    "cron-parser": "^4.9.0",
    "fuse.js": "^7.3.0",
    "ink": "^6.8.0",
    "js-yaml": "^4.1.0",
    "openai": "^4.47.0",
    "ora": "^8.0.1",
    "react": "^19.2.5",
    "sparkly": "^6.0.1",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.0.0",
    "@types/react": "^19.2.14",
    "@vitest/coverage-v8": "^4.1.1",
    "ink-testing-library": "^4.0.0",
    "tsup": "^8.0.0",
    "tsx": "^4.7.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.1"
  },
  "keywords": [
    "llm",
    "eval",
    "benchmark",
    "ollama",
    "mlx",
    "openai",
    "moe",
    "local-ai"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hnshah/verdict.git"
  },
  "homepage": "https://github.com/hnshah/verdict#readme",
  "bugs": {
    "url": "https://github.com/hnshah/verdict/issues"
  },
  "author": "Hiten Shah"
}
