{
  "name": "verdict",
  "version": "0.1.0",
  "description": "LLM eval framework. Benchmark local and cloud models with one config file.",
  "type": "module",
  "bin": {
    "verdict": "./dist/cli/index.js"
  },
  "scripts": {
    "build": "tsup src/cli/index.ts --format esm --target node20 --out-dir dist/cli --clean --banner.js '#!/usr/bin/env node' --shims",
    "dev": "npx tsx src/cli/index.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^12.0.0",
    "js-yaml": "^4.1.0",
    "openai": "^4.47.0",
    "ora": "^8.0.1",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.0.0",
    "tsup": "^8.0.0",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0"
  },
  "keywords": ["llm", "eval", "benchmark", "ollama", "mlx", "openai"],
  "license": "MIT"
}
